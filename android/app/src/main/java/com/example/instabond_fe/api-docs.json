{"openapi":"3.1.0","info":{"title":"Instabond API","description":"REST API documentation for Instabond mobile application","contact":{"name":"Instabond Team","email":"dev@instabond.com"},"version":"v1.0.0"},"servers":[{"url":"http://localhost:8080","description":"Generated server url"}],"security":[{"bearerAuth":[]}],"tags":[{"name":"Authentication","description":"Register, login and refresh token"},{"name":"Users","description":"View and update user profiles, followers and following lists"},{"name":"Posts","description":"Create, read, update and delete posts"}],"paths":{"/api/users/{id}":{"get":{"tags":["Users"],"summary":"Get profile by user ID","description":"Returns the full profile of a user by their `userId`.\n\n**Used for:** Profile Screen — displays user info alongside post count, followers and following.\n","operationId":"getProfile","parameters":[{"name":"id","in":"path","description":"MongoDB ObjectId of the user","required":true,"schema":{"type":"string"},"example":"64f1a2b3c4d5e6f7a8b9c0d1"}],"responses":{"200":{"description":"ProfileResponse returned successfully","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ProfileResponse"}}}},"401":{"description":"Missing or expired access token","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ProfileResponse"}}}},"404":{"description":"User not found","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ProfileResponse"}}}}},"security":[{"bearerAuth":[]}]},"put":{"tags":["Users"],"summary":"Update profile","description":"Update the authenticated user's profile information.\n\n- Only the **owner** of the profile can update it (`{id}` must match the token).\n- Fields not included in the request body will **retain their current values**.\n- Updatable fields: `full_name`, `bio`, `phone_number`, `settings`.\n","operationId":"updateProfile","parameters":[{"name":"id","in":"path","description":"ID of the user to update","required":true,"schema":{"type":"string"},"example":"64f1a2b3c4d5e6f7a8b9c0d1"}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpdateProfileRequest"}}},"required":true},"responses":{"200":{"description":"Profile updated successfully — returns updated ProfileResponse","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ProfileResponse"}}}},"401":{"description":"Missing or expired access token","content":{"*/*":{"schema":{"type":"object"}}}},"400":{"description":"Invalid request data","content":{"*/*":{"schema":{"type":"object"}}}},"403":{"description":"Forbidden — cannot update another user's profile","content":{"*/*":{"schema":{"type":"object"}}}},"404":{"description":"User not found","content":{"*/*":{"schema":{"type":"object"}}}}},"security":[{"bearerAuth":[]}]}},"/api/users/{id}/avatar":{"put":{"tags":["Users"],"summary":"Update profile avatar","description":"Uploads a new avatar to Cloudinary and updates the `avatar_url` in the database.\n\n- **Content-Type:** `multipart/form-data`\n- **`file`** (required): Image file (jpg, png, webp, ...)\n- Only the **owner** of the profile can change the avatar.\n","operationId":"updateAvatar","parameters":[{"name":"id","in":"path","description":"ID of the user","required":true,"schema":{"type":"string"},"example":"64f1a2b3c4d5e6f7a8b9c0d1"}],"requestBody":{"content":{"multipart/form-data":{"schema":{"type":"object","properties":{"file":{"type":"string","format":"binary","description":"New avatar image file"}},"required":["file"]}}}},"responses":{"401":{"description":"Missing or expired access token","content":{"*/*":{"schema":{"type":"object"}}}},"403":{"description":"Forbidden — cannot update another user's avatar","content":{"*/*":{"schema":{"type":"object"}}}},"400":{"description":"Missing or invalid file","content":{"*/*":{"schema":{"type":"object"}}}},"404":{"description":"User not found","content":{"*/*":{"schema":{"type":"object"}}}},"200":{"description":"Avatar updated successfully — returns updated ProfileResponse","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ProfileResponse"}}}}},"security":[{"bearerAuth":[]}]}},"/api/posts/{postId}":{"get":{"tags":["Posts"],"summary":"Get post by ID","description":"Returns full details of a single post by its postId.","operationId":"getPost","parameters":[{"name":"postId","in":"path","description":"Post ID","required":true,"schema":{"type":"string"},"example":"64f1a2b3c4d5e6f7a8b9c0d1"}],"responses":{"404":{"description":"Post not found","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}},"200":{"description":"Post returned successfully","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}},"401":{"description":"Missing or expired access token","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}}},"security":[{"bearerAuth":[]}]},"put":{"tags":["Posts"],"summary":"Update a post","description":"Only the author of the post is allowed to update it.\n\nFields that can be updated: caption, location, tagged_users.\nFields omitted from the request body will retain their current values.\n","operationId":"updatePost","parameters":[{"name":"postId","in":"path","description":"ID of the post to update","required":true,"schema":{"type":"string"},"example":"64f1a2b3c4d5e6f7a8b9c0d1"}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpdatePostRequest"}}},"required":true},"responses":{"403":{"description":"Forbidden — caller is not the post author","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}},"404":{"description":"Post not found","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}},"401":{"description":"Missing or expired access token","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}},"200":{"description":"Post updated successfully","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}}},"security":[{"bearerAuth":[]}]},"delete":{"tags":["Posts"],"summary":"Delete a post","description":"Only the author of the post is allowed to delete it. Returns HTTP 204 on success.","operationId":"deletePost","parameters":[{"name":"postId","in":"path","description":"ID of the post to delete","required":true,"schema":{"type":"string"},"example":"64f1a2b3c4d5e6f7a8b9c0d1"}],"responses":{"403":{"description":"Forbidden — caller is not the post author"},"404":{"description":"Post not found"},"401":{"description":"Missing or expired access token"},"204":{"description":"Post deleted successfully"}},"security":[{"bearerAuth":[]}]}},"/api/posts":{"post":{"tags":["Posts"],"summary":"Create a new post","description":"Create a post using a JSON body. Include media URLs directly in the `media` array.\n\nSend `Authorization: Bearer <token>` header.\n","operationId":"createPost","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreatePostRequest"}}},"required":true},"responses":{"400":{"description":"Invalid request body","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}},"201":{"description":"Post created successfully","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}},"401":{"description":"Missing or expired token","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}}},"security":[{"bearerAuth":[]}]}},"/api/auth/register":{"post":{"tags":["Authentication"],"summary":"Register a new account","description":"Create a new user with username, email and password. Avatar URL is optional.","operationId":"register","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AuthRequest"}}},"required":true},"responses":{"200":{"description":"Registration successful — returns accessToken & refreshToken","content":{"*/*":{"schema":{"type":"object"}}}},"400":{"description":"Validation failed or email/username already exists","content":{"*/*":{"schema":{"type":"object"}}}}},"security":[]}},"/api/auth/refresh":{"post":{"tags":["Authentication"],"summary":"Refresh access token","description":"Exchange a valid refreshToken for a new accessToken. Pass the refreshToken as `Authorization: Bearer <refreshToken>`.","operationId":"refresh","parameters":[{"name":"Authorization","in":"header","required":true,"schema":{"type":"string"}}],"responses":{"400":{"description":"Missing Authorization header","content":{"*/*":{"schema":{"type":"object"}}}},"401":{"description":"Refresh token is invalid or expired","content":{"*/*":{"schema":{"type":"object"}}}},"200":{"description":"Returns new accessToken, old refreshToken is kept","content":{"*/*":{"schema":{"type":"object"}}}}},"security":[]}},"/api/auth/login":{"post":{"tags":["Authentication"],"summary":"Login","description":"Authenticate with email and password. Returns accessToken (1 day) and refreshToken (7 days).","operationId":"login","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AuthRequest"}}},"required":true},"responses":{"200":{"description":"Login successful — returns accessToken & refreshToken","content":{"*/*":{"schema":{"type":"object"}}}},"401":{"description":"Invalid email or password","content":{"*/*":{"schema":{"type":"object"}}}}},"security":[]}},"/api/users":{"get":{"tags":["Users"],"summary":"Get all users","description":"Returns a list of profiles for all users in the system, including posts_count, followers_count and following_count.","operationId":"getAllUsers","responses":{"200":{"description":"List of ProfileResponse returned successfully","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ProfileResponse"}}}},"401":{"description":"Missing or expired access token","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/ProfileResponse"}}}}}},"security":[{"bearerAuth":[]}]}},"/api/users/{id}/following":{"get":{"tags":["Users"],"summary":"Get following list","description":"Returns a list of users that `{id}` is following (relationship status = accepted).","operationId":"getFollowing","paramete