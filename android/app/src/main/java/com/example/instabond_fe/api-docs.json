hemas/ProfileResponse"}}}},"401":{"description":"Missing or expired access token","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ProfileResponse"}}}},"404":{"description":"Username not found","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ProfileResponse"}}}}},"security":[{"bearerAuth":[]}]}},"/api/users/me":{"get":{"tags":["Users"],"summary":"Get current user profile","description":"Returns basic info of the authenticated user derived from the JWT token (id, username, email, full_name, avatar_url, bio).","operationId":"getMe","responses":{"403":{"description":"Access denied","content":{"*/*":{"schema":{"type":"object"}}}},"200":{"description":"Current user info returned successfully","content":{"*/*":{"schema":{"type":"object"}}}},"401":{"description":"Missing or expired access token","content":{"*/*":{"schema":{"type":"object"}}}}},"security":[{"bearerAuth":[]}]}},"/api/test":{"get":{"tags":["test-controller"],"operationId":"pingPong","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"object","additionalProperties":{"type":"string"}}}}}}}},"/api/posts/user/{userId}":{"get":{"tags":["Posts"],"summary":"Get all posts by userId","description":"Returns all posts authored by the given userId, sorted by newest first.","operationId":"getPostsByUserId","parameters":[{"name":"userId","in":"path","description":"ID of the target user","required":true,"schema":{"type":"string"},"example":"65b111111111111111111111"}],"responses":{"200":{"description":"List of the user's posts","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}},"401":{"description":"Missing or expired access token","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/PostResponse"}}}}},"404":{"description":"User not found","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/PostResponse"}}}}}},"security":[{"bearerAuth":[]}]}},"/api/posts/user/by-username/{username}":{"get":{"tags":["Posts"],"summary":"Get all posts by username","description":"Returns all posts authored by the given username, sorted by newest first.","operationId":"getPostsByUsername","parameters":[{"name":"username","in":"path","description":"Username of the target user","required":true,"schema":{"type":"string"},"example":"nam_nguyen"}],"responses":{"200":{"description":"List of the user's posts","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}},"401":{"description":"Missing or expired access token","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/PostResponse"}}}}},"404":{"description":"User not found","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/PostResponse"}}}}}},"security":[{"bearerAuth":[]}]}},"/api/posts/user/by-email/{email}":{"get":{"tags":["Posts"],"summary":"Get all posts by email","description":"Returns all posts authored by the given email, sorted by newest first.","operationId":"getPostsByEmail","parameters":[{"name":"email","in":"path","description":"Email of the target user","required":true,"schema":{"type":"string"},"example":"nam@example.com"}],"responses":{"200":{"description":"List of the user's posts","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}},"401":{"description":"Missing or expired access token","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/PostResponse"}}}}},"404":{"description":"User not found","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/PostResponse"}}}}}},"security":[{"bearerAuth":[]}]}},"/api/posts/feed":{"get":{"tags":["Posts"],"summary":"Get post feed","description":"Returns all posts sorted by newest first, used for the Home Feed screen.","operationId":"getFeed","responses":{"200":{"description":"List of posts returned successfully","content":{"*/*":{"schema":{"$ref":"#/components/schemas/PostResponse"}}}},"401":{"description":"Missing or expired access toke