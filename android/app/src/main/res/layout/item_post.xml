<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginTop="0dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="24dp"
    app:cardBackgroundColor="@color/feed_surface"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <FrameLayout
                android:id="@+id/fl_avatar_ring"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/feed_story_active_ring"
                android:padding="2dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/iv_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/avatar_circle_bg"
                    android:contentDescription="@string/cd_user_avatar"
                    android:scaleType="centerCrop"
                    tools:src="@tools:sample/avatars" />

            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="@id/fl_avatar_ring"
                app:layout_constraintEnd_toStartOf="@id/btn_overflow"
                app:layout_constraintStart_toEndOf="@id/fl_avatar_ring"
                app:layout_constraintTop_toTopOf="@id/fl_avatar_ring">

                <TextView
                    android:id="@+id/tv_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/login_text_primary"
                    android:textSize="14sp"
                    tools:text="elara_designs" />

                <TextView
                    android:id="@+id/tv_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.05"
                    android:textColor="@color/feed_story_label"
                    android:textSize="10sp"
                    tools:text="MILAN, ITALY" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_overflow"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/cd_more_options"
                android:padding="4dp"
                android:src="@drawable/ic_more_horizontal"
                app:layout_constraintBottom_toBottomOf="@id/fl_avatar_ring"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/fl_avatar_ring"
                app:tint="@color/feed_icon_dark" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <FrameLayout
            android:id="@+id/fl_post_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/iv_post_image"
                    android:layout_width="match_parent"
                    android:layout_height="360dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/cd_post_image"
                    android:scaleType="centerCrop"
                    tools:src="@tools:sample/backgrounds/scenic" />

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tv_image_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/feed_image_count_bg"
                android:fontFamily="sans-serif-bold"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp"
                android:textColor="@color/login_text_primary"
                android:textSize="10sp"
                tools:text="1/3" />

        </FrameLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageButton
                    android:id="@+id/btn_like"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/cd_like"
                    android:padding="2dp"
                    android:src="@drawable/ic_heart"
                    app:tint="@color/feed_icon_dark" />

                <TextView
                    android:id="@+id/tv_like_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="@color/login_text_primary"
                    android:textSize="12sp"
                    tools:text="2,842" />

                <ImageButton
                    android:id="@+id/btn_comment"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="16dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/cd_comment"
                    android:padding="2dp"
                    android:src="@drawable/ic_message_circle"
                    app:tint="@color/feed_icon_dark" />

                <TextView
                    android:id="@+id/tv_comment_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="@color/login_text_primary"
                    android:textSize="12sp"
                    tools:text="148" />

                <ImageButton
                    android:id="@+id/btn_share"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:visibility="gone" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_bookmark"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/cd_bookmark"
                android:padding="2dp"
                android:src="@drawable/ic_bookmark"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/feed_icon_dark" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tv_caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif"
            android:lineSpacingExtra="2dp"
            android:maxLines="4"
            android:textColor="@color/login_text_primary"
            android:textSize="14sp"
            tools:text="elara_designs Capturing the rhythmic soul of the city. Asymmetry is the ultimate form of perfection. ✨ #Editorial #Vibe" />

        <TextView
            android:id="@+id/tv_view_comments"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/feed_story_label"
            android:textSize="11sp"
            tools:text="View all 148 comments" />

        <TextView
            android:id="@+id/tv_time_ago"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.1"
            android:textColor="@color/feed_meta"
            android:textSize="9sp"
            tools:text="2 HOURS AGO" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
