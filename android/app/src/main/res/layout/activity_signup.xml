<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/login_card_surface"
    android:fillViewport="true"
    android:overScrollMode="never"
    tools:context=".view.SignUpActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="844dp"
        android:background="@color/login_card_surface">

        <View
            android:id="@+id/v_glow_top"
            android:layout_width="256dp"
            android:layout_height="256dp"
            android:layout_marginTop="-96dp"
            android:layout_marginEnd="-96dp"
            android:background="@drawable/signup_glow_top_right"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/v_glow_bottom"
            android:layout_width="256dp"
            android:layout_height="256dp"
            android:layout_marginStart="-96dp"
            android:layout_marginBottom="-96dp"
            android:background="@drawable/signup_glow_bottom_left"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/top_bar"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingEnd="24dp"
            android:paddingBottom="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btn_back"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/cd_back"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/login_bg_start" />

            <TextView
                android:id="@+id/tv_brand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="@string/login_brand_name"
                android:textColor="@color/login_bg_mid"
                android:textSize="24sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/content_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="56dp"
            android:paddingEnd="24dp"
            android:paddingBottom="56dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/top_bar">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:lineSpacingExtra="-2sp"
                android:text="@string/signup_title"
                android:textColor="@color/login_text_primary"
                android:textSize="36sp" />

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif"
                android:text="@string/signup_subtitle"
                android:textColor="@color/login_text_secondary"
                android:textSize="18sp" />

            <LinearLayout
                android:id="@+id/form_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:fontFamily="sans-serif-bold"
                    android:letterSpacing="0.05"
                    android:text="@string/signup_username_label"
                    android:textColor="@color/login_text_secondary"
                    android:textSize="14sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/signup_input_height"
                    android:layout_marginTop="12dp">

                    <EditText
                        android:id="@+id/et_username"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/signup_input_bg"
                        android:fontFamily="sans-serif-medium"
                        android:hint="@string/signup_username_hint"
                        android:importantForAutofill="yes"
                        android:inputType="text"
                        android:paddingStart="48dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/login_text_primary"
                        android:textColorHint="@color/signup_hint_text"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="start|center_vertical"
                        android:layout_marginStart="16dp"
                        android:fontFamily="sans-serif-bold"
                        android:gravity="center"
                        android:text="@string/signup_username_icon"
                        android:textColor="@color/signup_icon_tint"
                        android:textSize="20sp" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="24dp"
                    android:fontFamily="sans-serif-bold"
                    android:letterSpacing="0.05"
                    android:text="@string/signup_email_label"
                    android:textColor="@color/login_text_secondary"
                    android:textSize="14sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/signup_input_height"
                    android:layout_marginTop="12dp">

                    <EditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/signup_input_bg"
                        android:fontFamily="sans-serif-medium"
                        android:hint="@string/signup_email_hint"
                        android:importantForAutofill="yes"
                        android:inputType="textEmailAddress"
                        android:paddingStart="48dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/login_text_primary"
                        android:textColorHint="@color/signup_hint_text"
                        android:textSize="16sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="start|center_vertical"
                        android:layout_marginStart="16dp"
                        android:contentDescription=""
                        android:src="@drawable/ic_mail"
                        app:tint="@color/signup_icon_tint" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="24dp"
                    android:fontFamily="sans-serif-bold"
                    android:letterSpacing="0.05"
                    android:text="@string/signup_password_label"
                    android:textColor="@color/login_text_secondary"
                    android:textSize="14sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/signup_input_height"
                    android:layout_marginTop="12dp">

                    <EditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/signup_input_bg"
                        android:fontFamily="sans-serif-medium"
                        android:hint="********"
                        android:importantForAutofill="yes"
                        android:inputType="textPassword"
                        android:paddingStart="48dp"
                        android:paddingEnd="52dp"
                        android:textColor="@color/login_text_primary"
                        android:textColorHint="@color/signup_hint_text"
                        android:textSize="16sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="start|center_vertical"
                        android:layout_marginStart="16dp"
                        android:contentDescription=""
                        android:src="@drawable/ic_lock"
                        app:tint="@color/signup_icon_tint" />

                    <ImageButton
                        android:id="@+id/btn_toggle_password"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="16dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="@string/cd_toggle_password"
                        android:padding="0dp"
                        android:src="@drawable/ic_eye"
                        app:tint="@color/signup_icon_tint" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="24dp"
                    android:fontFamily="sans-serif-bold"
                    android:letterSpacing="0.05"
                    android:text="@string/signup_confirm_password_label"
                    android:textColor="@color/login_text_secondary"
                    android:textSize="14sp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/signup_input_height"
                    android:layout_marginTop="12dp">

                    <EditText
                        android:id="@+id/et_confirm_password"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/signup_input_bg"
                        android:fontFamily="sans-serif-medium"
                        android:hint="********"
                        android:importantForAutofill="yes"
                        android:inputType="textPassword"
                        android:paddingStart="48dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/login_text_primary"
                        android:textColorHint="@color/signup_hint_text"
                        android:textSize="16sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="start|center_vertical"
                        android:layout_marginStart="16dp"
                        android:contentDescription=""
                        android:src="@drawable/ic_shield_check"
                        app:tint="@color/signup_icon_tint" />

                </FrameLayout>

                <LinearLayout
                    android:id="@+id/btn_signup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/signup_primary_button_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingTop="20dp"
                    android:paddingBottom="20dp">

                    <TextView
                        android:id="@+id/tv_signup_cta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/signup_button"
                        android:textColor="@android:color/white"
                        android:textSize="18sp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginStart="12dp"
                        android:contentDescription=""
                        android:src="@drawable/ic_arrow_right_small"
                        app:tint="@android:color/white" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/row_signin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="@string/signup_already_have_account"
                    android:textColor="@color/login_text_secondary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tv_login_now"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="@string/signup_signin_action"
                    android:textColor="@color/login_bg_start"
                    android:textSize="16sp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
