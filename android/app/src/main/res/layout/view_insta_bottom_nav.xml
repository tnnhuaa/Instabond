<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_total_height">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/bottom_nav_height"
            android:layout_gravity="bottom">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_gravity="top"
                android:background="@color/divider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/bottom_nav_height"
                android:layout_marginTop="1dp"
                android:background="@color/signin_surface"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:weightSum="5">

                <LinearLayout
                    android:id="@+id/nav_home"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:minHeight="44dp"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iv_nav_home"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/nav_home"
                        android:src="@drawable/ic_home" />

                    <TextView
                        android:id="@+id/tv_nav_home"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/nav_home"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/nav_search"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:minHeight="44dp"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iv_nav_search"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/nav_search"
                        android:src="@drawable/ic_search" />

                    <TextView
                        android:id="@+id/tv_nav_search"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/nav_search"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />

                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <LinearLayout
                    android:id="@+id/nav_notifications"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:minHeight="44dp"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iv_nav_notifications"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/nav_notifications"
                        android:src="@drawable/ic_bell" />

                    <TextView
                        android:id="@+id/tv_nav_notifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/nav_notifications"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/nav_profile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal"
                    android:minHeight="44dp"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iv_nav_profile"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="@string/nav_profile"
                        android:src="@drawable/ic_person" />

                    <TextView
                        android:id="@+id/tv_nav_profile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/nav_profile"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <ImageButton
            android:id="@+id/btn_create"
            android:layout_width="@dimen/profile_fab_size"
            android:layout_height="@dimen/profile_fab_size"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="@dimen/bottom_nav_create_margin_bottom"
            android:background="@drawable/profile_create_btn_bg"
            android:contentDescription="@string/nav_create"
            android:elevation="6dp"
            android:padding="14dp"
            android:src="@drawable/ic_add_circle" />

    </FrameLayout>

</merge>
