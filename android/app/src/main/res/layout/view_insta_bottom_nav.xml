<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/feed_bottom_nav_bg"
        android:elevation="10dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="28dp"
        android:paddingTop="12dp"
        android:paddingEnd="28dp"
        android:paddingBottom="24dp"
        android:weightSum="5">

        <FrameLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="@drawable/feed_bottom_nav_active_bg"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/iv_nav_home"
                android:layout_width="16dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@string/nav_home"
                android:src="@drawable/ic_home" />

        </FrameLayout>

        <FrameLayout
            android:id="@+id/nav_search"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/iv_nav_search"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@string/nav_search"
                android:src="@drawable/ic_search" />

        </FrameLayout>

        <FrameLayout
            android:id="@+id/btn_create"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/iv_nav_create"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:contentDescription="@string/nav_create"
                android:src="@drawable/ic_add_circle" />

        </FrameLayout>

        <FrameLayout
            android:id="@+id/nav_notifications"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/iv_nav_notifications"
                android:layout_width="20dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@string/nav_notifications"
                android:src="@drawable/ic_heart" />

        </FrameLayout>

        <FrameLayout
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <ImageView
                android:id="@+id/iv_nav_profile"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:contentDescription="@string/nav_profile"
                android:src="@drawable/ic_person" />

        </FrameLayout>

    </LinearLayout>

</merge>
