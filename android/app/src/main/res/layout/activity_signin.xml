<?xml version="1.0" encoding="utf-8"?>
<!--
    InstaBond – Sign-In Screen
    Design node: 6:124 | Figma file: ZNm4rCJCuY8paZvdTkA5d1

    Screen is a dark full-bleed layout (bg #0A0A0F → #1A1A2E gradient) containing:
      1. App logo + brand name + tagline
      2. Đăng nhập / Đăng ký tab switcher
      3. Username + Password inputs
      4. "Remember password" checkbox row
      5. Primary gradient login button
      6. "or" divider
      7. Sign-in with Google button
      8. "No account? Register now" link
      9. Terms text
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true"
    android:overScrollMode="never"
    tools:context=".SignInActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="917dp"
        android:paddingStart="@dimen/signin_screen_margin"
        android:paddingEnd="@dimen/signin_screen_margin"
        android:paddingTop="96dp"
        android:paddingBottom="32dp">

        <!-- ──────────── LOGO ──────────── -->
        <!--
            Figma node 6:128: 90×90dp rounded-square with teal border +
            heart icon centred inside.
        -->
        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:contentDescription="@string/cd_app_logo"
            android:src="@drawable/ic_app_logo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- ──────────── BRAND NAME (node 6:139) ──────────── -->
        <!--
            Gradient text is not natively supported in XML TextView; we use a
            teal colour as the closest approximation. A custom GradientTextView
            can be swapped in at runtime for the full visual.
        -->
        <TextView
            android:id="@+id/tv_brand"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:text="InstaBond"
            android:textColor="#7EC8E3"
            android:textSize="@dimen/signin_brand_text"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_logo" />

        <!-- ──────────── TAGLINE (node 6:141) ──────────── -->
        <TextView
            android:id="@+id/tv_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif"
            android:text="@string/tagline"
            android:textColor="@color/signin_muted"
            android:textSize="@dimen/signin_tagline_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_brand" />

        <!-- ──────────── TAB CONTAINER (node 6:142) ──────────── -->
        <!--
            Dark pill container holding two equal-width tabs.
            Left tab (Đăng nhập) has a translucent gradient background pill (active).
        -->
        <FrameLayout
            android:id="@+id/container_tabs"
            android:layout_width="0dp"
            android:layout_height="@dimen/signin_tab_height"
            android:layout_marginTop="40dp"
            android:background="@drawable/signin_tab_container_bg"
            android:padding="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_tagline">

            <!-- Active tab background pill (left half) -->
            <View
                android:id="@+id/v_tab_indicator"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:background="@drawable/signin_tab_active_bg" />

            <!-- Tab row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- Đăng nhập tab -->
                <TextView
                    android:id="@+id/tv_tab_signin"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="@string/tab_signin"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <!-- Đăng ký tab -->
                <TextView
                    android:id="@+id/tv_tab_signup"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="@string/tab_signup"
                    android:textColor="@color/signin_tab_inactive"
                    android:textSize="14sp" />

            </LinearLayout>

        </FrameLayout>

        <!-- ──────────── USERNAME INPUT (node 6:148) ──────────── -->
        <FrameLayout
            android:id="@+id/container_username"
            android:layout_width="0dp"
            android:layout_height="@dimen/signin_input_height"
            android:layout_marginTop="@dimen/signin_form_gap"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/container_tabs">

            <EditText
                android:id="@+id/et_username"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/signin_input_bg"
                android:fontFamily="sans-serif"
                android:hint="@string/hint_signin"
                android:inputType="text"
                android:paddingStart="48dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/signin_hint"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/iv_icon_user"
                android:layout_width="@dimen/signin_icon_size"
                android:layout_height="@dimen/signin_icon_size"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:contentDescription=""
                android:src="@drawable/ic_user" />

        </FrameLayout>

        <!-- ──────────── PASSWORD INPUT (node 6:154) ──────────── -->
        <FrameLayout
            android:id="@+id/container_password"
            android:layout_width="0dp"
            android:layout_height="@dimen/signin_input_height"
            android:layout_marginTop="@dimen/signin_form_gap"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/container_username">

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/signin_input_bg"
                android:fontFamily="sans-serif"
                android:hint="@string/hint_password"
                android:inputType="textPassword"
                android:paddingStart="48dp"
                android:paddingEnd="48dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/signin_hint"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/iv_icon_lock"
                android:layout_width="@dimen/signin_icon_size"
                android:layout_height="@dimen/signin_icon_size"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:contentDescription=""
                android:src="@drawable/ic_lock" />

            <ImageButton
                android:id="@+id/btn_toggle_password"
                android:layout_width="@dimen/signin_icon_size"
                android:layout_height="@dimen/signin_icon_size"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/cd_toggle_password"
                android:src="@drawable/ic_eye" />

        </FrameLayout>

        <!-- ──────────── REMEMBER PASSWORD (node 6:164) ──────────── -->
        <LinearLayout
            android:id="@+id/row_remember"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/container_password">

            <CheckBox
                android:id="@+id/cb_remember"
                android:layout_width="@dimen/signin_checkbox_size"
                android:layout_height="@dimen/signin_checkbox_size"
                android:background="@drawable/signin_checkbox_bg"
                android:button="@null"
                android:checked="false" />

            <TextView
                android:id="@+id/tv_remember"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/label_remember"
                android:textColor="@color/signin_muted"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- ──────────── PRIMARY LOGIN BUTTON (node 6:168) ──────────── -->
        <Button
            android:id="@+id/btn_signin"
            android:layout_width="0dp"
            android:layout_height="@dimen/signin_btn_height"
            android:layout_marginTop="@dimen/signin_form_gap"
            android:background="@drawable/signin_btn_primary_bg"
            android:fontFamily="sans-serif-medium"
            android:stateListAnimator="@null"
            android:text="@string/btn_signin"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/row_remember" />

        <!-- ──────────── "OR" DIVIDER (node 6:170) ──────────── -->
        <LinearLayout
            android:id="@+id/row_divider"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/signin_form_gap"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_signin">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/signin_divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:fontFamily="sans-serif"
                android:text="@string/label_or"
                android:textColor="@color/signin_hint"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/signin_divider" />

        </LinearLayout>

        <!-- ──────────── GOOGLE SIGN-IN BUTTON (node 6:175) ──────────── -->
        <Button
            android:id="@+id/btn_google"
            android:layout_width="0dp"
            android:layout_height="@dimen/signin_input_height"
            android:layout_marginTop="@dimen/signin_form_gap"
            android:background="@drawable/signin_btn_google_bg"
            android:drawableStart="@drawable/ic_google"
            android:drawablePadding="12dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:stateListAnimator="@null"
            android:text="@string/btn_google"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/row_divider" />

        <!-- ──────────── NO ACCOUNT? REGISTER (node 6:182) ──────────── -->
        <LinearLayout
            android:id="@+id/row_register"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/signin_form_gap"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btn_google">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:text="@string/text_no_account"
                android:textColor="@color/signin_terms"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_register_now"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/btn_register_now"
                android:textColor="@color/signin_link"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- ──────────── TERMS (node 6:186) ──────────── -->
        <TextView
            android:id="@+id/tv_terms"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:text="@string/terms_full"
            android:textColor="@color/signin_terms"
            android:textSize="10sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/row_register" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
