<?xml version="1.0" encoding="utf-8"?>
<!--
    InstaBond Dimension Tokens
    Derived from Figma frame measurements (original canvas 439dp wide)
-->
<resources>

    <!-- ── Spacing ───────────────────────────────────────── -->
    <!-- General horizontal content padding (≈ node offset 15.98dp) -->
    <dimen name="spacing_horizontal">14dp</dimen>
    <!-- Vertical gap between icon rows (node 2:637 top = 11.99dp) -->
    <dimen name="spacing_row_vertical">12dp</dimen>
    <!-- Small inner padding -->
    <dimen name="spacing_small">8dp</dimen>
    <dimen name="spacing_xsmall">4dp</dimen>

    <!-- ── Post Header ───────────────────────────────────── -->
    <!-- Header height (node 2:624 height = 67.97dp) -->
    <dimen name="post_header_height">68dp</dimen>
    <!-- Avatar ring outer size (node 2:627 size = 43.99dp) -->
    <dimen name="avatar_ring_size">44dp</dimen>
    <!-- Avatar ring border width (padding inside ring = 1.998dp ≈ 2dp) -->
    <dimen name="avatar_ring_border">2dp</dimen>
    <!-- Avatar image inner size (node 2:628 size = 39.998dp) -->
    <dimen name="avatar_image_size">40dp</dimen>

    <!-- ── Post Image ─────────────────────────────────────── -->
    <!-- Music badge size (node 2:631 size = 31.97dp ≈ 32dp) -->
    <dimen name="music_badge_size">32dp</dimen>
    <!-- Music icon inside badge (node 2:632 size = 15.98dp ≈ 16dp) -->
    <dimen name="music_icon_size">16dp</dimen>
    <!-- Music badge margin from image edges -->
    <dimen name="music_badge_margin">8dp</dimen>

    <!-- ── Action Row ─────────────────────────────────────── -->
    <!-- Action icon touch target / size (node 2:639, 2:642, etc. = 24dp) -->
    <dimen name="action_icon_size">24dp</dimen>
    <!-- Gap between like and comment icons (40dp - 24dp = 16dp) -->
    <dimen name="action_icon_gap">16dp</dimen>

    <!-- ── Typography ────────────────────────────────────── -->
    <!-- App bar title size -->
    <dimen name="text_app_title">22sp</dimen>
    <!-- Body / username / likes text (node 2:626, 2:648, etc.) -->
    <dimen name="text_body">16sp</dimen>
    <!-- View comments small text (node 2:652) -->
    <dimen name="text_caption_small">14sp</dimen>

    <!-- ── Bottom Navigation ─────────────────────────────── -->
    <dimen name="bottom_nav_height">64dp</dimen>

    <!-- ── Toolbar ────────────────────────────────────────── -->
    <dimen name="toolbar_height">56dp</dimen>

</resources>
