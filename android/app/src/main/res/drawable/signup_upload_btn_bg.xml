<?xml version="1.0" encoding="utf-8"?>
<!--
    Background for the "Tải ảnh lên" upload button on the Sign-Up screen.
    Figma node 6:216 — #141419 fill, 1dp border rgba(209,237,249,0.2), radius 14dp.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <solid android:color="@color/signin_surface" />

    <!-- rgba(209,237,249,0.2) ≈ #33D1EDF9 -->
    <stroke
        android:width="1dp"
        android:color="#33D1EDF9" />

    <corners android:radius="14dp" />

</shape>
