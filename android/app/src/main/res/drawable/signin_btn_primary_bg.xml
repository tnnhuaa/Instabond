<?xml version="1.0" encoding="utf-8"?>
<!--
    Primary login button background: top-to-bottom gradient (light-blue → gold).
    Figma node 6:168 — gradient 180° from #D1EDF9 to #D5AD41, radius 16dp.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <gradient
        android:angle="270"
        android:startColor="@color/signin_grad_start"
        android:endColor="@color/signin_grad_end"
        android:type="linear" />

    <corners android:radius="16dp" />

</shape>
