<?xml version="1.0" encoding="utf-8"?>
<!--
    Small red notification dot badge shown on the messages icon in the toolbar.
    8dp circle, fill #EF4444 (standard red).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <solid android:color="#EF4444" />

    <size
        android:height="8dp"
        android:width="8dp" />

</shape>
